<div ng-controller="ApplicationAccountsReceivables" ng-if="grantFile.ShowAccountsReceivables">
    <span class="panel-section-item">
        <span class="panel-section-title" ng-click="toggle($event)">Accounts Receivables</span>
        <span class="panel-section-buttons">
            <span><button class="btn btn--empty" style="pointer-events: none;" tabindex="-1">&nbsp;</button></span>
            <span><button class="btn btn--empty" style="pointer-events: none;" tabindex="-1">&nbsp;</button></span>
            <section-edit-buttons ng-model="section.editing" ng-if="grantFile.EditAccountsReceivables"></section-edit-buttons>
            <span class="small" ng-class="section.show ? 'up-arrow': 'down-arrow'" ng-click="toggle($event)"></span>
        </span>
    </span>
    <div class="panel-section-content" ng-if="section.show">
        <div class="form">
            <table>
                <thead>
                <tr>
                    <th>Overpayment Category</th>
                    <th>WDA Overpayment $</th>
                    <th>LMDA Overpayment $</th>
                    <th>Overpayment $ (Historical)</th>
                    <td colspan="2"></td>
                </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="accountsReceivable in model.Records">
                        <td class="white-cell">
                            {{ accountsReceivable.ServiceCategoryName }}
                        </td>
                        <td class="white-cell" ng-if="section.editing">
                            <input type="text" ng-model="accountsReceivable.OverpaymentWDA" class="input-inline-align input-right-align" ng-currency="13" ng-validation="errors.Records_{{accountsReceivable.ServiceCategoryId}}_OverpaymentWDA" />
                        </td>
                        <td class="white-cell" ng-if="section.editing">
                            <input type="text" ng-model="accountsReceivable.OverpaymentLMDA" class="input-inline-align input-right-align" ng-currency="13" ng-validation="errors.Records_{{accountsReceivable.ServiceCategoryId}}_OverpaymentLMDA" />
                        </td>
                        <td class="white-cell text--right" ng-if="!section.editing">
                            <span ng-validation="errors.Records_{{accountsReceivable.ServiceCategoryId}}_ServiceCategoryId">{{ accountsReceivable.OverpaymentWDA | currency : '$' : 2 }}</span>
                        </td>
                        <td class="white-cell text--right" ng-if="!section.editing">
                            <span ng-validation="errors.Records_{{accountsReceivable.ServiceCategoryId}}_ServiceCategoryId">{{ accountsReceivable.OverpaymentLMDA | currency : '$' : 2 }}</span>
                        </td>
                        <td class="white-cell text--right">
                            {{ accountsReceivable.Overpayment | currency : '$' : 2 }}
                        </td>
                        <td class="white-cell" colspan="2">
                            <input type="hidden" ng-model="accountsReceivable.Overpayment" class="input-inline-align input-right-align" ng-currency="13" />
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                <tr>
                    <th>Totals</th>
                    <th class="text--right">{{ rowTotalWDA(model.Records) | currency : '$' : 2}}</th>
                    <th class="text--right">{{ rowTotalLMDA(model.Records) | currency : '$' : 2}}</th>
                    <th class="text--right">{{ rowTotalHistorical(model.Records) | currency : '$' : 2}}</th>
                    <td colspan="2"></td>
                </tr>
                </tfoot>

            </table>
            
            <div class="form__group">
                <div class="form__label">Date Accounts Receivable Created</div>
                <div class="form__control">
                    <div class="control-wrapper">
                        <div class="control-wrapper" ng-if="section.editing">
                            <datedropdown ng-model="model.AccountsReceivablePaidDate" ng-text="model.AccountsReceivablePaidDate" ng-min-date="section.earliestAccountsReceivableDate" ng-max-date="section.latestAccountsReceivableDate" ng-editing="section.editing"></datedropdown>
                        </div>
                        <div class="control-wrapper" ng-if="!section.editing">
                            <span ng-bind="model.AccountsReceivablePaidDateFormatted"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
